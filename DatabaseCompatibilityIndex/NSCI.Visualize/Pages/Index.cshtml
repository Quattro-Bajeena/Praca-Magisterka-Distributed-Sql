@page
@model IndexModel
@{
    ViewData["Title"] = "Database Test Dashboard";
}

<div class="container-fluid">
    <h1 class="mb-4">SQL Compatibility Test Dashboard</h1>

    @if (Model.Databases.Count == 0)
    {
        <div class="alert alert-warning">
            <h4>No test data available</h4>
            <p>Run tests first to see results here.</p>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3>Database Comparison</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="comparisonChart" style="max-height: 400px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            @foreach (var db in Model.Databases)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@db.Name</h5>
                            <small>@db.Type</small>
                        </div>
                        <div class="card-body">
                            <div class="text-center mb-3">
                                <canvas id="chart-@db.Id" style="max-height: 200px;"></canvas>
                            </div>
                            <div class="stats">
                                <p class="mb-2">
                                    <strong>Total Tests:</strong> @db.TotalTests
                                </p>
                                <p class="mb-2 text-success">
                                    <strong>Passed:</strong> @db.PassedTests
                                </p>
                                <p class="mb-2 text-danger">
                                    <strong>Failed:</strong> @db.FailedTests
                                </p>
                                @if (db.Result.HasValue)
                                {
                                    <p class="mb-2">
                                        <strong>Success Rate:</strong> @((db.Result.Value * 100).ToString("F2"))%
                                    </p>
                                }
                            </div>
                        </div>
                        <div class="card-footer">
                            <a href="/Database?id=@db.Id" class="btn btn-primary btn-sm w-100">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Individual database charts
        @foreach (var db in Model.Databases)
        {
            <text>
            new Chart(document.getElementById('chart-@db.Id'), {
                type: 'doughnut',
                data: {
                    labels: ['Passed', 'Failed'],
                    datasets: [{
                        data: [@db.PassedTests, @db.FailedTests],
                        backgroundColor: ['#28a745', '#dc3545']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
            </text>
        }

        // Comparison chart
        @if (Model.ComparisonData != null && Model.ComparisonData.Categories.Count > 0)
        {
            <text>
            const comparisonData = {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ComparisonData.Categories)),
                datasets: [
                    @foreach (var kvp in Model.ComparisonData.DatabasePassRates)
                    {
                        <text>
                        {
                            label: '@kvp.Key',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(kvp.Value)),
                            borderWidth: 2,
                            fill: false
                        },
                        </text>
                    }
                ]
            };

            new Chart(document.getElementById('comparisonChart'), {
                type: 'radar',
                data: comparisonData,
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        r: {
                            beginAtZero: true,
                            max: 100,
                            ticks: {
                                stepSize: 20
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        title: {
                            display: true,
                            text: 'Category Pass Rate Comparison (%)'
                        }
                    }
                }
            });
            </text>
        }
    </script>
}

