@page
@model DatabaseModel
@{
    ViewData["Title"] = Model.Database?.Name ?? "Database Details";
}

@if (Model.Database == null)
{
    <div class="alert alert-danger">Database not found.</div>
}
else
{
    <div class="container-fluid">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                <li class="breadcrumb-item active">@Model.Database.Name</li>
            </ol>
        </nav>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h2 class="mb-0">@Model.Database.Name</h2>
                        <small>@Model.Database.Type</small>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h4>Overall Statistics</h4>
                                <table class="table">
                                    <tbody>
                                        <tr>
                                            <th>Total Tests:</th>
                                            <td>@Model.Database.TotalTests</td>
                                        </tr>
                                        <tr class="table-success">
                                            <th>Passed:</th>
                                            <td>@Model.Database.PassedTests</td>
                                        </tr>
                                        <tr class="table-danger">
                                            <th>Failed:</th>
                                            <td>@Model.Database.FailedTests</td>
                                        </tr>
                                        @if (Model.Database.Result.HasValue)
                                        {
                                            <tr>
                                                <th>Success Rate:</th>
                                                <td><strong>@((Model.Database.Result.Value * 100).ToString("F2"))%</strong></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <canvas id="overallChart" style="max-height: 250px;"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3>Category Breakdown</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="categoryChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3>Test Results by Category</h3>
                    </div>
                    <div class="card-body">
                        @foreach (var category in Model.CategoryStats.OrderBy(c => c.Key))
                        {
                            <div class="mb-4">
                                <h4>@category.Key</h4>
                                <div class="mb-2">
                                    <span class="badge bg-primary">Total: @category.Value.Total</span>
                                    <span class="badge bg-success">Passed: @category.Value.Passed</span>
                                    <span class="badge bg-danger">Failed: @category.Value.Failed</span>
                                    <span class="badge bg-info">Pass Rate: @category.Value.PassRate.ToString("F2")%</span>
                                </div>
                                
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead>
                                            <tr>
                                                <th>Status</th>
                                                <th>Test Name</th>
                                                <th>Class</th>
                                                <th>Description</th>
                                                <th>Duration</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var test in Model.TestResults.Where(t => t.Category == category.Key))
                                            {
                                                <tr class="@(test.Passed ? "table-success" : "table-danger")">
                                                    <td>
                                                        @if (test.Passed)
                                                        {
                                                            <span class="badge bg-success">✓ Pass</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger">✗ Fail</span>
                                                        }
                                                    </td>
                                                    <td>@test.Name</td>
                                                    <td><small>@test.ClassName</small></td>
                                                    <td>@test.Description</td>
                                                    <td><small>@test.Duration</small></td>
                                                </tr>
                                                @if (!test.Passed && !string.IsNullOrEmpty(test.Error))
                                                {
                                                    <tr class="table-danger">
                                                        <td colspan="5">
                                                            <strong>Error:</strong>
                                                            <pre class="mb-0" style="font-size: 0.8rem; white-space: pre-wrap;">@test.Error</pre>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        @if (Model.Database != null)
        {
            <text>
            // Overall chart
            new Chart(document.getElementById('overallChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Passed', 'Failed'],
                    datasets: [{
                        data: [@Model.Database.PassedTests, @Model.Database.FailedTests],
                        backgroundColor: ['#28a745', '#dc3545']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Category chart
            const categoryData = {
                labels: [@Html.Raw(string.Join(",", Model.CategoryStats.Keys.Select(k => $"'{k}'")))],
                datasets: [{
                    label: 'Passed',
                    data: [@Html.Raw(string.Join(",", Model.CategoryStats.Values.Select(v => v.Passed)))],
                    backgroundColor: '#28a745'
                }, {
                    label: 'Failed',
                    data: [@Html.Raw(string.Join(",", Model.CategoryStats.Values.Select(v => v.Failed)))],
                    backgroundColor: '#dc3545'
                }]
            };

            new Chart(document.getElementById('categoryChart'), {
                type: 'bar',
                data: categoryData,
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        x: {
                            stacked: true
                        },
                        y: {
                            stacked: true,
                            beginAtZero: true
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
            </text>
        }
    </script>
}
